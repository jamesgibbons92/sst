{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "sst",
  "type": "module",
  "sideEffects": [
    "./dist/resource/node.js",
    "./dist/resource/cloudflare.js"
  ],
  "version": "0.0.0",
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/sst.git"
  },
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./resource": {
      "types": "./dist/resource/index.d.ts",
      "workerd": "./dist/resource/cloudflare.js",
      "worker": "./dist/resource/cloudflare.js",
      "default": "./dist/resource/node.js"
    },
    "./resource/cloudflare": {
      "types": "./dist/resource/cloudflare.d.ts",
      "default": "./dist/resource/cloudflare.js"
    },
    "./auth": "./dist/auth/index.js",
    "./auth/adapter": "./dist/auth/adapter/index.js",
    "./event": "./dist/event/index.js",
    "./realtime": "./dist/realtime/index.js",
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "release": "./scripts/release.ts"
  },
  "devDependencies": {
    "@aws/durable-execution-sdk-js-testing": "^1.1.1",
    "@tsconfig/node20": "20.1.4",
    "@types/aws-lambda": "^8.10.155",
    "@types/node": "22.10.0",
    "bun-types": "1.3.0",
    "hono": "4.3.9",
    "typescript": "5.7.2",
    "valibot": "^1.0.0-rc.3",
    "zod": "^3.24.2"
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "sst": "./bin/sst.mjs"
  },
  "optionalDependencies": {},
  "dependencies": {
    "@aws/durable-execution-sdk-js": "1.0.2",
    "aws4fetch": "1.0.18",
    "jose": "5.2.3",
    "openid-client": "5.6.4"
  }
}
